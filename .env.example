# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenAI (for AI tag extraction + smart matching)
# ⚠️ MOVE TO SUPABASE EDGE FUNCTION - DO NOT USE IN CLIENT
# VITE_OPENAI_API_KEY=your_openai_key_here

# Groq (free, fast — for tag extraction + translation)
# ⚠️ MOVE TO SUPABASE EDGE FUNCTION - DO NOT USE IN CLIENT
# VITE_GROQ_API_KEY=your_groq_key_here

# Airwallex Payment (get credentials at https://www.airwallex.com/hk)
# Set AIRWALLEX_ENV=prod for production
VITE_AIRWALLEX_ENV=demo
# VITE_AIRWALLEX_CLIENT_ID=your_client_id_here  ← set in Supabase Edge Function env, NOT here
